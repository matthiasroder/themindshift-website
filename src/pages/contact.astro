---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Contact" description="Book a discovery call or send us a message.">

  <PageHero
    label="Contact"
    title='Let&apos;s <span class="text-ms-green-400">talk.</span>'
    subtitle="Two ways to reach us. Pick whichever feels right."
  />

  <section class="bg-ms-dark-800 border-y border-white/5">
    <div class="max-w-6xl mx-auto px-6 py-24">
      <div class="grid md:grid-cols-2 gap-16">

        <!-- Book a Call -->
        <div>
          <h2 class="text-2xl font-bold mb-4">Book a Discovery Call</h2>
          <p class="text-gray-400 leading-relaxed mb-8">
            30 minutes. Free. No obligations. We'll listen to your situation and tell you honestly if and how we can help.
          </p>
          <a href="https://calendar.app.google/H72LRQ2RAgXyN4oS9" target="_blank" rel="noopener"
            class="block bg-ms-green-500 hover:bg-ms-green-400 text-ms-dark-900 px-8 py-4 rounded-full font-semibold text-lg transition text-center">
            Book a Discovery Call →
          </a>
        </div>

        <!-- Send a Message -->
        <div>
          <h2 class="text-2xl font-bold mb-4">Send a Message</h2>
          <p class="text-gray-400 leading-relaxed mb-8">
            Rather write? Tell us what's on your mind.
          </p>
          <a href="mailto:info@themindshift.global?subject=The%20Mindshift%20—%20Inquiry" 
            class="block border border-white/20 hover:border-white/40 text-white px-8 py-4 rounded-full font-semibold text-lg transition text-center">
            ✉️ info@themindshift.global
          </a>
          <p class="mt-4 text-sm text-gray-500">We respond within 48 hours. Usually faster.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Location -->
  <section class="bg-ms-dark-900">
    <div class="max-w-6xl mx-auto px-6 py-16 text-center">
      <p class="text-gray-500">Based in Salzburg. Working across Europe and beyond.</p>
    </div>
  </section>

</Layout>
