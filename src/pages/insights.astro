---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import CTA from '../components/CTA.astro';
---

<Layout title="Insights" description="Thinking about AI strategy, creativity, and transformation.">

  <PageHero
    label="Insights"
    title='Thinking about AI, <span class="text-ms-green-400">out loud.</span>'
    subtitle="Opinions, frameworks, and lessons from the field. No '10 AI trends you need to know' listicles."
  />

  <section class="bg-ms-dark-800 border-y border-white/5">
    <div class="max-w-3xl mx-auto px-6 py-24">
      <div class="space-y-12">
        {[
          {
            title: "The Earned Autonomy Gradient: When Can You Trust AI to Act Alone?",
            date: "February 4, 2026",
            excerpt: "A mechanism to know whether to trust your AI or not. Hint: it is not about capability benchmarks. It is about what the AI does when it does not know.",
            href: "/insights/the-earned-autonomy-gradient"
          },
          {
            title: "The Halo Organization: Why Your AI Pilots Keep Failing",
            date: "February 3, 2026",
            excerpt: "42% of companies abandoned most AI initiatives in 2025. The problem is not the technology. It is the pyramid structure you are bolting it onto.",
            href: "/insights/the-halo-organization"
          },
          {
            title: "The Future is Ambient AI",
            date: "January 28, 2026",
            excerpt: "We have been thinking about AI wrong. It is not about making chatbots better. It is about a presence that knows you and is always there.",
            href: "/insights/the-future-is-ambient-ai"
          },
          {
            title: "Ideas Are Everything",
            date: "January 21, 2026",
            excerpt: "For decades, the startup mantra was: Ideas are nothing, execution is everything. That wisdom is inverting.",
            href: "/insights/ideas-are-everything"
          }
        ].map(article => (
          <a href={article.href} class="block group">
            <p class="text-sm text-gray-500 mb-2">{article.date}</p>
            <h2 class="text-2xl md:text-3xl font-bold group-hover:text-ms-green-400 transition">{article.title}</h2>
            <p class="mt-3 text-gray-400 leading-relaxed">{article.excerpt}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTA />

</Layout>
