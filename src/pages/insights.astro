---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import CTA from '../components/CTA.astro';
---

<Layout title="Insights" description="Thinking about AI strategy, creativity, and transformation.">

  <PageHero
    label="Insights"
    title='Thinking about AI, <span class="text-ms-green-400">out loud.</span>'
    subtitle="Opinions, frameworks, and lessons from the field. No '10 AI trends you need to know' listicles."
  />

  <section class="bg-ms-dark-800 border-y border-white/5">
    <div class="max-w-3xl mx-auto px-6 py-24 text-center">
      <p class="text-lg text-gray-400">Articles coming soon.</p>
      <p class="text-gray-500 mt-4">In the meantime, check out Dr. Röder's writing on <a href="https://matthiasroder.com" class="text-ms-green-400 hover:text-ms-green-300 transition" target="_blank" rel="noopener">matthiasroder.com</a></p>
    </div>
  </section>

  <CTA />

</Layout>
